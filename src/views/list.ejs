<%- include('./includes/head', { pageCSS: pageCSS }) %>
<%- include('./includes/nav') %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Ocorrências</h2>
    <a href="/mapa" class="btn btn-outline-primary">+ Nova ocorrência</a>
  </div>

  <% if (success && success.length > 0) { %>
    <div class="alert alert-success"><%= success[0] %></div>
  <% } %>

  <% if (occurrences.length === 0) { %>
    <p class="text-muted">Nenhuma ocorrência registrada ainda.</p>
  <% } %>

  <div class="row g-3">
    <% occurrences.forEach(occ => { %>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <span class="badge bg-secondary mb-2"><%= occ.type %></span>
            <h5 class="card-title"><%= occ.street %></h5>
            <p class="card-text text-muted mb-1"><%= occ.district %></p>
            <p class="card-text">
              <small class="text-muted">
                Por: <%= occ.user ? occ.user.name : 'Anônimo' %>
              </small>
            </p>
          </div>
          <div class="card-footer d-flex gap-2">
            <a href="/ocorrencias/<%= occ.id %>" class="btn btn-sm btn-outline-secondary">
              🔍 Ver detalhes
            </a>
            <!-- Botão de editar só aparece se o usuário logado for o autor -->
            <!-- Isso é proteção de UI — a proteção real está no controller -->
            <% if (currentUserId && currentUserId === occ.userId) { %>
              <a href="/ocorrencias/<%= occ.id %>/editar" class="btn btn-sm btn-outline-primary">
                ✏ Editar
              </a>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<%- include('./includes/footer') %>