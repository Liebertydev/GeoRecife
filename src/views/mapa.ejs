<%- include('./includes/head', { pageCSS: pageCSS }); %>
  <%- include('./includes/nav') %>

    <div class="container-fluid overflow-hidden p-0" id="map-wrapper">
      <div class="row g-0 h-100">

        <!-- Sidebar (25%) -->
        <div class="col-3 bg-success text-white p-3 d-flex flex-column" style="min-width: 250px; overflow-y: auto;">
          <h4 class="mb-4">Filtros do Mapa</h4>

          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="filterCrimes" value="crime">
            <label class="form-check-label" for="filterCrimes">Crimes</label>
          </div>

          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="filterTraffic" value="transito">
            <label class="form-check-label" for="filterTraffic">Trânsito</label>
          </div>

          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="filterBuracos" value="buraco">
            <label class="form-check-label" for="filterBuracos">Buracos na via</label>
          </div>

          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="filterAlagamento" value="alagamento">
            <label class="form-check-label" for="filterAlagamento">Alagamento</label>
          </div>

          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="filterEntulho" value="entulho">
            <label class="form-check-label" for="filterEntulho">Entulho/Descarte irregular</label>
          </div>

          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="filterIluminacao" value="iluminacao">
            <label class="form-check-label" for="filterIluminacao">Iluminação</label>
          </div>

          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="filterOthers" value="outros">
            <label class="form-check-label" for="filterOthers">Outros</label>
          </div>


          <button class="btn btn-light mt-auto" id="filtrarOcc">Aplicar Filtros</button>
        </div>

        <!-- Área do mapa (75%) -->
        <div class="col p-0 position-relative">
          <div id="map" style="height: 100%; width: 100%;"></div>

          <!-- Barra de busca -->
          <div class="position-absolute top-0 start-50 translate-middle-x mt-3"
            style="z-index: 1000; max-width: 600px; width: 75%;">
            <div class="input-group">
              <input type="text" id="searchInput" class="form-control" placeholder="Busque por um local"
                autocomplete="off">
              <button type="button" class="btn btn-primary" id="searchBtn">Buscar</button>
            </div>
            <div id="suggestions" class="list-group"></div>
          </div>

          <!-- Botão registrar ocorrência -->
          <div class="position-absolute bottom-0 start-50 translate-middle-x mb-4" style="z-index: 1000;">
            <button type="button" id="btnRegistrarOcorrencia">
              Registrar ocorrência
            </button>
          </div>
        </div>

      </div>
    </div>

    <div style="position: fixed; bottom: -9999px; left: -9999px; visibility: hidden;">
      <%- include('./includes/footer') %>
    </div>

    <script>
      const navbar = document.querySelector('nav.navbar');
      const wrapper = document.getElementById('map-wrapper');
      if (navbar && wrapper) {
        wrapper.style.height = (window.innerHeight - navbar.offsetHeight) + 'px';
      }
    </script>