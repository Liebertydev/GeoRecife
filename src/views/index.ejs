  <div class="row g-4"> <!-- g-4 adiciona espaçamento entre colunas -->

    <!-- Pessoa 1 -->
    <div class="col-12 col-md-4">
      <h5>Heitor</h5>
      <p>Responsáveis pela pesquisa de dados e análise de ocorrências.</p>
    </div>

    <!-- Pessoa 2 -->
    <div class="col-12 col-md-4">
      <h5>Vanessa e Lufyo</h5>
      <p>Desenvolvimento Front-end, interfaces, validando o Front-end.</p>
    </div>

    <!-- Pessoa 3 -->
    <div class="col-12 col-md-4">
      <h5>Lieberty e Ananda</h5>
