// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  password    String
  createdAt   DateTime     @default(now())
  occurrences Occurrence[]
}


model Occurrence {
  id          Int      @id @default(autoincrement())
  title       String?
  description String?

  latitude    Float
  longitude   Float

  street      String
  district    String
  city        String   @default("Recife")
  postcode    String
  placeName   String?

  type        String

  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}

model Session {
  sid    String @id
  sess   Json
  expire DateTime

  @@map("session") // indica pro Prisma que a tabela existe, mas não vai alterar
}