<main class="hero">
  <!-- Conteúdo -->
<div class="container py-3 py-md-5">
  <div class="row align-items-stretch"> <!-- força as colunas a terem a mesma altura -->
    
    <!-- Texto e botão -->
    <div class="col-12 col-md-6 d-flex flex-column justify-content-center mb-3 mb-md-0 hero-text">
      <h1 class="">Geo Recife</h1>
      <p class="text-justify">
        Geo Recife é uma plataforma desenvolvida para monitorar a cidade, registrando ocorrências como acidentes, criminalidade e áreas de risco. Com dados atualizados e acessíveis, ela ajuda a população e autoridades a entender melhor a dinâmica da cidade e agir de forma mais eficiente.
      </p>
      <button class="btn btn-success px-4 align-self-start">Get Started</button>
    </div>
    
    <!-- Imagem/Mapa -->
    <div class="col-12 col-md-6 d-flex align-items-center justify-content-center">
      <img src="/assets/img/mapa3.png" alt="Mapa do Recife" class="img-fluid rounded">
    </div>

  </div>
</div>

<div class="container py-5">
